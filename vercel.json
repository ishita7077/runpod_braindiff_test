{
  "routes": [
    { "src": "^/api/(.*)$", "dest": "/api/$1" },
    { "src": "^/assets/(.*)$", "dest": "/frontend_new/assets/$1" },
    { "src": "^/demo/(.*)$", "dest": "/frontend_new/demo/$1" },
    { "src": "^/(.*\\.(?:css|js))$", "dest": "/frontend_new/$1" },
    { "src": "^/research/?$", "dest": "/frontend_new/research.html" },
    { "src": "^/research-new/?$", "dest": "/frontend_new/research-new.html" },
    { "src": "^/methodology/patterns/?$", "dest": "/frontend_new/methodology-patterns.html" },
    { "src": "^/methodology/connectivity/?$", "dest": "/frontend_new/methodology-connectivity.html" },
    { "src": "^/methodology/skeleton/?$", "dest": "/frontend_new/methodology-skeleton.html" },
    { "src": "^/methodology/?$", "dest": "/frontend_new/methodology.html" },
    { "src": "^/data/(.*)$", "dest": "/frontend_new/data/$1" },
    { "src": "^/launch/?$", "dest": "/frontend_new/input.html" },
    { "src": "^/run/?$", "dest": "/frontend_new/run.html" },
    { "src": "^/results/?$", "dest": "/frontend_new/results.html" },
    { "src": "^/video-results/?$", "dest": "/frontend_new/video-results.html" },
    { "src": "^/audio-results/?$", "dest": "/frontend_new/audio-results.html" },
    { "src": "^/dashboard/?$", "dest": "/frontend_new/dashboard.html" },
    { "src": "^/admin/?$", "dest": "/frontend_new/admin.html" },
    { "src": "^/$", "dest": "/frontend_new/index.html" },
    { "src": "^(.*)$", "dest": "/frontend_new/$1" }
  ]
}
