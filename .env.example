# Runpod
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# Cloudflare Turnstile (optional — leave both unset to skip bot check, e.g. local/private testing)
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Optional rate limits
RATE_LIMIT_TEXT_PER_DAY=10
RATE_LIMIT_MEDIA_PER_DAY=5
RATE_LIMIT_BURST_PER_MINUTE=3

# Optional cleanup TTL (seconds)
BLOB_DELETE_AFTER_SECONDS=86400

# Existing BrainDiff runtime vars used by worker
TRIBEV2_REVISION=facebook/tribev2
BRAIN_DIFF_ATLAS_DIR=atlases
BRAIN_DIFF_NARRATIVE_TONE=sober
RUNPOD_MEDIA_MAX_MB=200
